# Spotify (create app at https://developer.spotify.com/dashboard)
# Client Credentials work for public playlists; use OAuth for private playlists.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# Optional: for private playlists (OAuth). Set redirect URI in Spotify Dashboard to http://localhost:8080/callback
# SPOTIFY_REDIRECT_URI=http://localhost:8080/callback

# Navidrom (Subsonic API)
NAVIDROM_URL=https://your-navidrom-server.com
NAVIDROM_USER=your_username
NAVIDROM_PASSWORD=your_password
